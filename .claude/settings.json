{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",

    "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx prisma *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)"
    ]
},
    "language": "Korean",
    "outputStyle": "Explanatory"
}
  